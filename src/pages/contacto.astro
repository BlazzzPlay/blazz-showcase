---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { resolveSeoPage } from '../lib/seo/catalog';

const contactoSeo = resolveSeoPage('/contacto');
---

<Layout seo={contactoSeo}>
  <Navigation />
  <main class="section-padding" id="contacto">
    <section class="container page-hero" aria-labelledby="contacto-title">
      <p class="eyebrow">Contacto profesional</p>
      <h1 id="contacto-title">Contacto para iniciar tu proyecto digital en Chile hoy</h1>
      <p>
        Si necesitás una propuesta técnica clara para tu próximo producto, coordinemos una primera conversación.
        Te comparto alcance, prioridades y próximos pasos accionables.
      </p>
    </section>

    <section class="container glass contact-card" aria-label="Canales de contacto">
      <h2>Canales disponibles</h2>
      <ul>
        <li>Email: <a href="mailto:blazzzplay@gmail.com">blazzzplay@gmail.com</a></li>
        <li>GitHub: <a href="https://github.com/BlazzzPlay" target="_blank" rel="noopener noreferrer">github.com/BlazzzPlay</a></li>
        <li>Formulario completo: <a href="/#contacto">ir al formulario en home</a></li>
      </ul>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .page-hero {
    max-width: 850px;
    text-align: center;
    margin-bottom: 2rem;
  }

  .eyebrow {
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: hsl(var(--accent-light));
    font-weight: 700;
    margin-bottom: 1rem;
    font-size: 0.8rem;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 1rem;
  }

  .page-hero p {
    color: hsl(var(--text-muted));
    line-height: 1.7;
  }

  .contact-card {
    max-width: 700px;
    margin: 0 auto;
    padding: 1.5rem;
    border-radius: 1rem;
  }

  .contact-card h2 {
    margin-bottom: 0.75rem;
  }

  .contact-card ul {
    list-style: none;
    display: grid;
    gap: 0.75rem;
    color: hsl(var(--text-muted));
  }

  .contact-card a {
    color: hsl(var(--primary-light));
  }
</style>
