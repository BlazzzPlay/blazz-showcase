---
const navItems = [
  { name: 'Inicio', href: '#inicio' },
  { name: 'Proyectos', href: '#proyectos' },
  { name: 'Sobre mí', href: '#sobre-mi' },
  { name: 'Contacto', href: '#contacto' },
];
---

<nav class="nav">
  <div class="container nav-content glass">
    <div class="logo">
      <h1 class="gradient-text">Blazz</h1>
    </div>
    <ul class="nav-links">
      {navItems.map(item => (
        <li><a href={item.href}>{item.name}</a></li>
      ))}
    </ul>
    <div class="nav-action">
      <a href="#contacto" class="btn btn-primary d-none-mobile">Contáctame</a>
      <button class="mobile-menu-btn" aria-label="Toggle menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </button>
    </div>
  </div>

  <div class="mobile-menu glass">
    <ul class="mobile-nav-links">
      {navItems.map(item => (
        <li><a href={item.href}>{item.name}</a></li>
      ))}
      <li><a href="#contacto" class="gradient-text">Contáctame</a></li>
    </ul>
  </div>
</nav>

<script>
  // Dynamic Navbar on Scroll
  const nav = document.querySelector('.nav') as HTMLElement;
  const navContent = document.querySelector('.nav-content') as HTMLElement;
  
  if (nav && navContent) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        navContent.classList.add('scrolled');
      } else {
        navContent.classList.remove('scrolled');
      }
    }, { passive: true });
  }

  // Mobile Menu Toggle
  const mobileMenuBtn = document.querySelector('.mobile-menu-btn');
  const mobileMenu = document.querySelector('.mobile-menu');
  const mobileLinks = document.querySelectorAll('.mobile-nav-links a');

  if (mobileMenuBtn && mobileMenu) {
    mobileMenuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('active');
    });

    mobileLinks.forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.remove('active');
      });
    });
  }
</script>

<style>
  .nav {
    position: fixed;
    top: 1.5rem;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 0 1rem;
    animation: slideDown 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 2rem;
    border-radius: 999px;
    max-width: 900px;
    transition: background 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .nav-content.scrolled {
    background: hsla(224, 71%, 4%, 0.85);
    backdrop-filter: blur(16px);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
    border-color: hsla(var(--primary-light) / 0.3);
  }

  .logo h1 {
    font-size: 1.5rem;
    margin: 0;
    font-weight: 800;
  }

  .nav-links {
    list-style: none;
    display: flex;
    gap: 2rem;
  }

  .nav-links a {
    color: hsl(var(--text-muted));
    font-size: 0.9rem;
    font-weight: 500;
  }

  .nav-links a:hover {
    color: hsl(var(--text));
  }

  .nav-action {
    display: flex;
  }

  .btn {
    padding: 0.5rem 1.25rem;
    font-size: 0.9rem;
  }

  @keyframes slideDown {
    from { transform: translateY(-30px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  @media (max-width: 768px) {
    .nav-links, .d-none-mobile {
      display: none;
    }

    .mobile-menu-btn {
      display: block;
    }

    .mobile-menu {
      display: block;
    }
  }

  .mobile-menu-btn {
    display: none;
    background: none;
    border: none;
    color: hsl(var(--text));
    cursor: pointer;
    padding: 0.5rem;
  }

  .mobile-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 1rem;
    right: 1rem;
    padding: 1.5rem;
    border-radius: 1.5rem;
    margin-top: 0.5rem;
    opacity: 0;
    transform: translateY(-10px);
    pointer-events: none;
    transition: all 0.3s ease;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
  }

  .mobile-menu.active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: all;
  }

  .mobile-nav-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    text-align: center;
  }

  .mobile-nav-links a {
    font-size: 1.1rem;
    font-weight: 600;
    color: hsl(var(--text-muted));
    display: block;
    padding: 0.5rem;
  }

  .mobile-nav-links a:hover, .mobile-nav-links a.gradient-text {
    color: hsl(var(--text));
  }
</style>
