---
const navItems = [
  { name: 'Inicio', href: '#inicio' },
  { name: 'Proyectos', href: '#proyectos' },
  { name: 'Sobre mí', href: '#sobre-mi' },
  { name: 'Contacto', href: '#contacto' },
];
---

<nav class="nav">
  <div class="container nav-content glass">
    <div class="logo">
      <h1 class="gradient-text">Blazz</h1>
    </div>
    <ul class="nav-links">
      {navItems.map(item => (
        <li><a href={item.href}>{item.name}</a></li>
      ))}
    </ul>
    <div class="nav-action">
      <a href="#contacto" class="btn btn-primary">Contáctame</a>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 1.5rem;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 0 1rem;
    animation: slideDown 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 2rem;
    border-radius: 999px;
    max-width: 900px;
  }

  .logo h1 {
    font-size: 1.5rem;
    margin: 0;
    font-weight: 800;
  }

  .nav-links {
    list-style: none;
    display: flex;
    gap: 2rem;
  }

  .nav-links a {
    color: hsl(var(--text-muted));
    font-size: 0.9rem;
    font-weight: 500;
  }

  .nav-links a:hover {
    color: hsl(var(--text));
  }

  .nav-action {
    display: flex;
  }

  .btn {
    padding: 0.5rem 1.25rem;
    font-size: 0.9rem;
  }

  @keyframes slideDown {
    from { transform: translateY(-30px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }
  }
</style>
