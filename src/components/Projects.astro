---
import { Image } from 'astro:assets';
import educalImg from '../assets/projects/educal.webp';

const projects = [
  {
    title: 'EduCal Chile',
    description: 'Plataforma digital integral que transforma el trabajo docente a través de soluciones intuitivas para la gestión educativa y evaluación curricular.',
    image: educalImg,
    tags: ['React', 'TypeScript', 'Vercel', 'SaaS', 'EdTech'],
    link: 'https://educal-chile.vercel.app/',
    badge: 'Producción'
  }
];
---

<section id="proyectos" class="projects" data-animate="fade-up" aria-labelledby="projects-title">
  <div class="container">
    <div class="section-header">
      <h2 id="projects-title" class="section-title">Trabajo <span class="gradient-text gradient-primary">Destacado</span></h2>
      <p class="section-description">Una muestra de las soluciones digitales que he desarrollado recientemente.</p>
    </div>
    
    <div class="projects-grid">
      {projects.map(project => (
        <article class="project-card glass" aria-labelledby={`project-${project.title.replace(/\s+/g, '-').toLowerCase()}-title`}>
          <div class="project-image">
            <Image src={project.image} alt={project.title} loading="lazy" width={800} height={450} />
            <div class="badge-overlay" aria-label={`Estado: ${project.badge}`}>{project.badge}</div>
            <div class="project-overlay">
              <a href={project.link} target="_blank" rel="noopener noreferrer" class="btn btn-primary" aria-label={`Abrir ${project.title} en una nueva pestaña`}>Ver Proyecto</a>
            </div>
          </div>
          <div class="project-info">
             <div class="project-tags">
               {project.tags.map(tag => (
                 <span class="tag">{tag}</span>
               ))}
             </div>
             <h3 class="project-title" id={`project-${project.title.replace(/\s+/g, '-').toLowerCase()}-title`}>{project.title}</h3>
             <p class="project-description">{project.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .projects {
    padding: 10rem 0;
  }

  .section-header {
    text-align: center;
    margin-bottom: 5rem;
  }

  .section-title {
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    margin-bottom: 1.5rem;
  }

  .section-description {
    color: hsl(var(--text-muted));
    font-size: 1.125rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: 3rem;
  }

  .project-card {
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
    display: flex;
    flex-direction: column;
    border-radius: 1.5rem;
    position: relative;
  }

  .project-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    border-radius: inherit;
    background: radial-gradient(800px circle at var(--mouse-x, 0) var(--mouse-y, 0), hsla(var(--primary-light), 0.1), transparent 40%);
    z-index: 1;
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  .project-card:hover {
    transform: translateY(-10px);
    border-color: hsl(var(--primary) / 0.5);
    box-shadow: 0 10px 40px -10px hsl(var(--primary) / 0.3);
  }

  .project-card:hover::before {
    opacity: 1;
  }

  .project-image {
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
    z-index: 2;
  }

  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .project-card:hover .project-image img {
    transform: scale(1.1);
  }

  .badge-overlay {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 5;
    background: hsla(1189, 74%, 43%, 0.85); /* Teal accent from design */
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 99px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    backdrop-filter: blur(4px);
  }

  .project-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .project-card:hover .project-overlay {
    opacity: 1;
  }

  .project-card:focus-within {
    transform: translateY(-10px);
    border-color: hsl(var(--primary) / 0.5);
    box-shadow: 0 10px 40px -10px hsl(var(--primary) / 0.3);
  }

  .project-card:focus-within .project-overlay {
    opacity: 1;
  }

  .project-info {
    padding: 2rem;
    position: relative;
    z-index: 2;
  }

  .project-tags {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.25rem 0.75rem;
    background: hsl(var(--primary) / 0.1);
    color: hsl(var(--primary-light));
    border: 1px solid hsla(var(--primary) / 0.2);
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .project-title {
    font-size: 1.75rem;
    margin-bottom: 1rem;
    font-family: var(--font-display);
    font-weight: 700;
  }

  .project-description {
    color: hsl(var(--text-muted));
    line-height: 1.6;
    font-size: 1rem;
  }

  .gradient-text.gradient-primary {
    background: linear-gradient(135deg, hsl(var(--primary-light)), hsl(var(--accent)));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  @media (max-width: 640px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
