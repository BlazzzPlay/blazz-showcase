{
  "name": "cyan-chroma",
  "type": "module",
  "version": "1.0.0",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview --host",
    "start": "node dist/server/entry.mjs",
    "astro": "astro",
    "typecheck": "tsc --noEmit",
    "quality:assert-lighthouse": "node scripts/assert-lighthouse.mjs",
    "seo:audit": "node --import tsx scripts/seo-audit.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:unit": "node --import tsx --test src/lib/seo/__tests__/*.test.ts"
  },
  "dependencies": {
    "@astrojs/node": "^10.0.3",
    "@astrojs/sitemap": "^3.7.2",
    "@libsql/client": "^0.17.2",
    "astro": "^6.0.8",
    "drizzle-orm": "^0.45.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
